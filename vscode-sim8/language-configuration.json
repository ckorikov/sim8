{
  "comments": {
    "lineComment": ";"
  },
  "brackets": [
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "wordPattern": "(-?0x[0-9A-Fa-f]+|\\b\\d+\\.\\d*|\\b\\.\\d+|\\b[01]+[bB]|\\b0o[0-7]+|[.A-Za-z_][A-Za-z0-9_]*)"
}
